<?xml version="1.0" encoding="UTF-8"?>
<!--
    Debug configuration for Adobe MCP Illustrator panel.
    Enables Chrome DevTools access for debugging the panel's JavaScript.
    Access at: http://localhost:8089 when Illustrator is running with the panel loaded.
-->
<ExtensionList>
    <Extension Id="com.adobemcp.ai.panel">
        <HostList>
            <Host Name="ILST" Port="8089" />
        </HostList>
    </Extension>
</ExtensionList>
