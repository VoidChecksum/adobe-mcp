<?xml version="1.0" encoding="UTF-8"?>
<!--
    Debug configuration for Adobe MCP Photoshop panel.
    Enables Chrome DevTools access for debugging the panel's JavaScript.
    Access at: http://localhost:8088 when Photoshop is running with the panel loaded.
-->
<ExtensionList>
    <Extension Id="com.adobemcp.ps.panel">
        <HostList>
            <Host Name="PHXS" Port="8088" />
            <Host Name="PHSP" Port="8088" />
        </HostList>
    </Extension>
</ExtensionList>
