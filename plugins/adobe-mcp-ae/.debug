<?xml version="1.0" encoding="UTF-8"?>
<!--
    Debug configuration for Adobe MCP After Effects panel.
    Enables Chrome DevTools access for debugging the panel's JavaScript.
    Access at: http://localhost:8090 when After Effects is running with the panel loaded.
-->
<ExtensionList>
    <Extension Id="com.adobemcp.ae.panel">
        <HostList>
            <Host Name="AEFT" Port="8090" />
        </HostList>
    </Extension>
</ExtensionList>
