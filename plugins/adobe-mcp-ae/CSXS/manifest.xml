<?xml version="1.0" encoding="UTF-8"?>
<!--
    CEP 12 Manifest — Adobe MCP Relay Panel for After Effects.

    This panel connects to the MCP WebSocket relay server and executes
    JSX code received from MCP tools via CSInterface.evalScript().
    It replaces the osascript subprocess path with a persistent,
    bidirectional connection.

    Installation:
        Run scripts/install-cep-panels.sh to symlink into the CEP extensions directory.
-->
<ExtensionManifest Version="12.0"
                   ExtensionBundleId="com.adobemcp.ae"
                   ExtensionBundleVersion="1.0.0"
                   ExtensionBundleName="Adobe MCP After Effects"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">

    <ExtensionList>
        <Extension Id="com.adobemcp.ae.panel" Version="1.0.0" />
    </ExtensionList>

    <ExecutionEnvironment>
        <HostList>
            <Host Name="AEFT" Version="[25.0,99.9]" />
        </HostList>
        <LocaleList>
            <Locale Code="All" />
        </LocaleList>
        <RequiredRuntimeList>
            <RequiredRuntime Name="CSXS" Version="12.0" />
        </RequiredRuntimeList>
    </ExecutionEnvironment>

    <DispatchInfoList>
        <Extension Id="com.adobemcp.ae.panel">
            <DispatchInfo>
                <Resources>
                    <MainPath>./index.html</MainPath>
                    <ScriptPath>../../shared/host/polyfills.jsx</ScriptPath>
                    <CEFCommandLine>
                        <Parameter>--allow-file-access-from-files</Parameter>
                    </CEFCommandLine>
                </Resources>
                <Lifecycle>
                    <AutoVisible>true</AutoVisible>
                    <StartOn>
                        <Event>com.adobe.csxs.events.ApplicationActivate</Event>
                    </StartOn>
                </Lifecycle>
                <UI>
                    <Type>Panel</Type>
                    <Menu>Adobe MCP</Menu>
                    <Geometry>
                        <Size>
                            <Height>200</Height>
                            <Width>250</Width>
                        </Size>
                        <MinSize>
                            <Height>150</Height>
                            <Width>200</Width>
                        </MinSize>
                    </Geometry>
                </UI>
            </DispatchInfo>
        </Extension>
    </DispatchInfoList>
</ExtensionManifest>
